# Copy to .env on the server and fill in values (never commit .env).
# cp env.template .env

PUBLIC_URL=https://workspaces.adeptengr.com
PUBLIC_HOST=workspaces.adeptengr.com
SERVER_IP=

# Kasm admin (email is the username in CE)
KASM_ADMIN_USER=admin@your-domain.com
KASM_ADMIN_PASSWORD=

# Optional default test user from install.sh
KASM_USER_USER=user@kasm.local
KASM_USER_PASSWORD=

# From /opt/kasm install output — required for scripts that talk to the API/DB
KASM_DB_PASSWORD=
KASM_REDIS_PASSWORD=
KASM_MANAGER_TOKEN=

# Persistent profiles on Desktop-server
PROFILES_PATH=/data/adept/kasm/profiles/{username}
