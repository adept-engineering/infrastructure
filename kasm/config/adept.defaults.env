# Non-secret defaults for Adept Kasm on Desktop-server.
# Secrets live in .env and .adept-users.env (gitignored).

ADEPT_PROFILES_PATH=/data/adept/kasm/profiles/{username}
ADEPT_MAX_SESSIONS=5
ADEPT_PLATFORM_RESERVE_MIB=6144
ADEPT_MIN_SESSION_MIB=1536
ADEPT_MAX_SESSION_MIB=10240
ADEPT_WORKSPACE_IMAGES="Ubuntu Noble Ubuntu Jammy Terminal Visual Studio Code Firefox"
ADEPT_USER_PREFIX=adept-u

PUBLIC_URL="${PUBLIC_URL:-https://workspaces.adeptengr.com}"
PUBLIC_HOST="${PUBLIC_HOST:-workspaces.adeptengr.com}"
KASM_HTTPS_PORT=9443
